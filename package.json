{
  "name": "globaldeets-landing",
  "version": "1.0.0",
  "description": "GlobalDeets - Business intelligence and data platform showcase",
  "main": "index.html",
  "scripts": {
    "dev": "vite --port 5500 --open",
    "format": "prettier --write \"**/*.{html,css,js,json}\"",
    "lint": "eslint \"**/*.js\"",
    "lint:fix": "eslint \"**/*.js\" --fix",
    "build": "npm run format",
    "deploy": "echo 'Ready to deploy to www.globaldeets.com'",
    "start": "npm run dev",
    "generate-icons": "node generate-icons.js",
    "health:prod": "node health-prod.js",
    "health:prod:json": "node health-prod.js --json"
  },
  "keywords": [
    "business-intelligence",
    "data-platforms",
    "analytics"
  ],
  "author": "GlobalDeets",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.11"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
